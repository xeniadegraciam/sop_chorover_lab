"μ(E): %{y:.4f}<extra>%{fullData.name}</extra>"
))
fig_xanes.update_layout(
title="Interactive XANES (Hover to track energy)",
xaxis_title="Energy (eV)",
yaxis_title="Normalized μ(E)",
# 🔥 THIS is what you want
hovermode="x unified",
template="simple_white",
height=500
)
fig_xanes
