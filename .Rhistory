from larch.io import read_athena
import plotly.graph_objects as go
import os
# 🔗 Path
path = r"D:/Research/FieldNotes/Synchrotron_HardDrive/Rob_Standards/Arsenic/"
filename = "As_refs_USB.prj"
full_path = os.path.join(path, filename)
print("File exists:", os.path.exists(full_path))
# 📊 Load Athena
project = read_athena(full_path)
print("Groups:", len(project.groups))
fig = go.Figure()
for name, grp in project.groups.items():
if getattr(grp, 'sel', 1) == 0:
continue
fig.add_trace(go.Scatter(
x=grp.energy,
y=grp.norm,
mode='lines',
name=name,
hovertemplate=
"Energy: %{x:.2f} eV<br>" +
"μ(E): %{y:.4f}<extra>%{fullData.name}</extra>"
))
fig.update_layout(
title="Interactive XANES",
xaxis_title="Energy (eV)",
yaxis_title="μ(E)",
hovermode="x unified"
)
fig
