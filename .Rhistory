def load_references(prj_path):
from larch.io import read_athena
project = read_athena(prj_path)
refs = {}
for name, group in project.groups.items():
if getattr(group, 'sel', 1) == 0:
continue
# ✅ Require normalized XANES
if not hasattr(group, 'norm'):
continue
refs[name] = {
"energy": group.energy,
"mu": group.norm,
"k": getattr(group, "k", None),
"chi_k3": (group.chi * group.k**3) if hasattr(group, "chi") and hasattr(group, "k") else None
}
return refs
# 🔗 Path
# 📁 Define datasets
data_paths = {
"Arsenic": r"D:/Research/FieldNotes/Synchrotron_HardDrive/Rob_Standards/Arsenic/As_refs_USB.prj",
"Sulfur":  r"D:/Research/FieldNotes/Synchrotron_HardDrive/Rob_Standards/Sulfur/S_refs_athena.prj",
"Iron":    r"D:/Research/FieldNotes/Synchrotron_HardDrive/RobTraining/Fe_SRP_refs_RR.prj"
}
for element, path in data_paths.items():
print(element," path exist? ", os.path.exists(path))
all_data = {}
for element, path in data_paths.items():
all_data[element] = load_references(path)
